# Server
PORT=3000

# MySQL / MariaDB (SCADA DB History)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=scada_history

# Polling
POLLING_INTERVAL_MS=5000
# Events older than this (in seconds) are considered "settled" and ready to process
SETTLING_SECONDS=15

# Wablas
WABLAS_TOKEN=your_wablas_token_here
WABLAS_SECRET_KEY=your_wablas_secret_key_here
WABLAS_BASE_URL=https://my.wablas.com

# Target grup WA — group ID dari menu Inbox Wablas (bukan @g.us)
# Contoh: 872468237asd-6281218xxxxxx
WA_GROUP_TARGETS=872468237asd-6281218xxxxxx

# Target nomor individu — format: 628xxxxxxxxxx (pisahkan koma jika lebih dari satu)
WA_NUMBER_TARGETS=
